# Copia questo file in ".env" e compila i valori necessari.
# Le variabili contrassegnate OBBLIGATORIA bloccano l'avvio dell'app se mancanti.
# Tutte le altre sono opzionali: se assenti, la relativa funzionalità è
# semplicemente disabilitata (l'app resta utilizzabile).

# ── Database ────────────────────────────────────────────────────────────────
# SQLite in locale (default se non impostata), PostgreSQL in produzione.
DATABASE_URL=sqlite:///./artigiani.db

# ── Sicurezza ────────────────────────────────────────────────────────────────
# OBBLIGATORIA. Stringa casuale di almeno 20 caratteri, usata per firmare le
# sessioni e i token CSRF. Generala con:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=

# Chiave per cifrare in database i dati più sensibili (es. coordinate
# bancarie). Senza questa chiave i dati vengono salvati in chiaro: opzionale
# ma fortemente raccomandata in produzione. Genera con:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# ── Email (verifica account, reset password, notifiche) ─────────────────────
# Configura UNO tra Resend, Brevo o SMTP generico. Se nessuno è impostato,
# l'invio email è disabilitato e la verifica email viene saltata in automatico.
RESEND_API_KEY=
BREVO_API_KEY=
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=Mastro <noreply@example.com>
# Email di destinazione per gli alert di sistema (es. backup falliti).
# Se assente, usa MAIL_FROM.
ADMIN_EMAIL=

# ── Pagamenti Stripe (piani a pagamento) ─────────────────────────────────────
# Se assenti, i piani a pagamento sono semplicemente disabilitati.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_STARTER=
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_BUSINESS=

# ── Cloudinary (upload foto/allegati lavori) ─────────────────────────────────
# Se assente, gli upload restano su disco locale (/uploads).
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# ── Notifiche push browser (Web Push / VAPID) ────────────────────────────────
# Se assenti, le notifiche push sono disabilitate. Genera la coppia con:
#   python -c "from pywebpush import generate_vapid_keys; print(generate_vapid_keys())"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ── Backup automatico su S3 (richiede PostgreSQL, non SQLite) ────────────────
# Se assenti, il backup giornaliero pianificato è disabilitato.
BACKUP_S3_BUCKET=
BACKUP_S3_KEY_ID=
BACKUP_S3_SECRET=
BACKUP_S3_ENDPOINT=
BACKUP_S3_REGION=auto

# ── Error tracking (Sentry) ──────────────────────────────────────────────────
# Se assente, gli errori non vengono inviati a un servizio esterno.
SENTRY_DSN=

# ── Deploy ───────────────────────────────────────────────────────────────────
# URL pubblico dell'app, usato nei link delle email e nei redirect Stripe.
# Se assente, viene derivato dalla richiesta in arrivo (va bene in locale).
BASE_URL=

# Codice promozionale statico per accesso gratuito al piano Pro in fase di
# registrazione. Opzionale, feature di marketing.
CODICE_PROMO=
